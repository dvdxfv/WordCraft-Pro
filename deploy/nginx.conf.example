# WordCraft Pro — Nginx 生产配置示例
# 使用前：
#   1. 将 your-domain.com 替换为实际域名
#   2. 将 /path/to/wordcraft-pro 替换为项目实际路径
#   3. 将 SSL 证书路径替换为腾讯云/Cloudflare 颁发的证书路径
#   4. 将此文件复制为 nginx.conf 并放入 Nginx conf.d/ 目录

# HTTP → HTTPS 跳转
server {
    listen 80;
    server_name your-domain.com www.your-domain.com;
    return 301 https://$host$request_uri;
}

# HTTPS 主服务
server {
    listen 443 ssl;
    server_name your-domain.com www.your-domain.com;

    # SSL 证书（腾讯云 / Cloudflare 均可）
    ssl_certificate     /path/to/ssl/your-domain.com.pem;
    ssl_certificate_key /path/to/ssl/your-domain.com.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # 大文件上传（docx/pdf 最大 100MB）
    client_max_body_size 100m;

    # 静态前端文件
    root /path/to/wordcraft-pro/web;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # 后端 API 反向代理
    location /api/ {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # QA 检查可能耗时较长
        proxy_read_timeout    300s;
        proxy_connect_timeout 60s;
        proxy_send_timeout    300s;
    }

    # Supabase Edge Function 代理（如使用）
    location /functions/ {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_read_timeout 120s;
    }

    # 日志
    access_log /var/log/nginx/wordcraft_access.log;
    error_log  /var/log/nginx/wordcraft_error.log;
}
