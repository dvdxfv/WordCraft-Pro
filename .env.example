# WordCraft Pro — 环境变量模板
# 使用方法：复制此文件为 .env，填入真实值（.env 已加入 .gitignore，不会上传）

# ===== AI 服务 =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== Supabase =====
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ===== Flask =====
FLASK_DEBUG=0
PORT=5000

# ===== 可选：邮件通知 =====
RESEND_API_KEY=
TEAM_INVITE_FROM_EMAIL=
TEAM_INVITE_EMAIL_WEBHOOK_URL=
